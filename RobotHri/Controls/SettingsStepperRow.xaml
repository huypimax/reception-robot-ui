<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.SettingsStepperRow">

    <!--
        Settings row with a label on the left and a [−] [value] [+] stepper on the right.
        Used for numeric settings such as volume percentages.
    -->
    <VerticalStackLayout Spacing="0">

        <Grid ColumnDefinitions="*,Auto"
              Padding="{StaticResource SettingsInfoRowPadding}">

            <Label Grid.Column="0"
                   x:Name="LabelView"
                   Style="{StaticResource BodyLabel}"
                   FontSize="{StaticResource FontSizeBody}"
                   VerticalOptions="Center" />

            <!-- Stepper: [−] | value badge | [+] -->
            <Border Grid.Column="1"
                    Stroke="{StaticResource LightBlue}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="0"
                    VerticalOptions="Center"
                    HeightRequest="40">

                <Grid ColumnDefinitions="48,1,Auto,1,48">

                    <!-- Minus button -->
                    <Border Grid.Column="0"
                            BackgroundColor="Transparent"
                            Stroke="Transparent"
                            x:Name="MinusBorder">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="MinusTap" />
                        </Border.GestureRecognizers>
                        <Label Text="−"
                               TextColor="{StaticResource TextDark}"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <!-- Left divider -->
                    <BoxView Grid.Column="1"
                             BackgroundColor="{StaticResource LightBlue}"
                             VerticalOptions="Fill" />

                    <!-- Value badge -->
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource PrimaryDarkBlue}"
                            Stroke="Transparent"
                            Padding="14,0">
                        <Label x:Name="ValueLabel"
                               TextColor="{StaticResource TextOnPrimary}"
                               FontFamily="RobotoBold"
                               FontSize="{StaticResource FontSizeBody}"
                               MinimumWidthRequest="60"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <!-- Right divider -->
                    <BoxView Grid.Column="3"
                             BackgroundColor="{StaticResource LightBlue}"
                             VerticalOptions="Fill" />

                    <!-- Plus button -->
                    <Border Grid.Column="4"
                            BackgroundColor="Transparent"
                            Stroke="Transparent"
                            x:Name="PlusBorder">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="PlusTap" />
                        </Border.GestureRecognizers>
                        <Label Text="+"
                               TextColor="{StaticResource TextDark}"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                </Grid>
            </Border>

        </Grid>

        <BoxView HeightRequest="1"
                 Color="{StaticResource LightBlue}"
                 HorizontalOptions="Fill" />

    </VerticalStackLayout>

</ContentView>
