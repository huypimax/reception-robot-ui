<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.SettingsInfoRow">

    <!--
        Read-only info row used in the System Settings panel.
        Shows a label on the left and its current value on the right,
        separated from the next row by a light hairline divider.
    -->
    <VerticalStackLayout Spacing="0">

        <Grid ColumnDefinitions="*,Auto"
              Padding="{StaticResource SettingsInfoRowPadding}">

            <Label Grid.Column="0"
                   x:Name="LabelView"
                   Style="{StaticResource BodyLabel}"
                   FontSize="{StaticResource FontSizeBody}"
                   TextColor="{StaticResource TextMuted}"
                   VerticalOptions="Center" />

            <Label Grid.Column="1"
                   x:Name="ValueView"
                   Style="{StaticResource BodyLabel}"
                   FontSize="{StaticResource FontSizeBody}"
                   TextColor="{StaticResource TextDark}"
                   HorizontalOptions="End"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Hairline divider -->
        <BoxView HeightRequest="1"
                 Color="{StaticResource LightBlue}"
                 HorizontalOptions="Fill" />

    </VerticalStackLayout>

</ContentView>
