<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.SettingsDropdownRow"
             x:Name="RootView">

    <VerticalStackLayout Spacing="0">

        <Grid ColumnDefinitions="*,Auto"
              Padding="{StaticResource SettingsInfoRowPadding}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer x:Name="RowTap" />
            </Grid.GestureRecognizers>

            <VerticalStackLayout Grid.Column="0"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <Label x:Name="LabelView"
                       Style="{StaticResource BodyLabel}"
                       FontSize="{StaticResource FontSizeBody}"
                       TextColor="{StaticResource TextDark}" />
                <Label x:Name="DescView"
                       Style="{StaticResource SubtitleLabel}"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextColor="{StaticResource TextMuted}"
                       IsVisible="False" />
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="1"
                                   Spacing="8"
                                   VerticalOptions="Center">
                <Label x:Name="ValueView"
                       TextColor="{StaticResource TextMuted}"
                       FontFamily="RobotoRegular"
                       FontSize="{StaticResource FontSizeBody}" />

                <Image x:Name="IconView"
                       WidthRequest="16"
                       HeightRequest="16"
                       Aspect="AspectFit" 
                       Source="icon_angle_down.png"/>
            </HorizontalStackLayout>

        </Grid>

        <BoxView HeightRequest="1"
                 Color="{StaticResource LightBlue}"
                 HorizontalOptions="Fill" />

    </VerticalStackLayout>

</ContentView>
