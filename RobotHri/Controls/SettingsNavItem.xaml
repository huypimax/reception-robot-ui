<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.SettingsNavItem">

    <!--
        Sidebar navigation item for the Settings page.
        Collapsed look: icon + text on a transparent background.
        Selected look : white icon + white text on a PrimaryDarkBlue rounded pill.
    -->
    <Grid Padding="8,2">
        <Border x:Name="SelectionBg"
                BackgroundColor="Transparent"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 8"
                HeightRequest="{StaticResource SettingsNavItemHeight}"
                Padding="{StaticResource SettingsNavItemInnerPadding}">

            <Border.GestureRecognizers>
                <TapGestureRecognizer x:Name="ItemTap" />
            </Border.GestureRecognizers>

            <HorizontalStackLayout Spacing="{StaticResource SettingsNavItemSpacing}"
                                   VerticalOptions="Center">
                <Label x:Name="IconLabel"
                       FontSize="{StaticResource SettingsNavIconSize}"
                       WidthRequest="{StaticResource SettingsNavIconWidth}"
                       HorizontalTextAlignment="Center"
                       VerticalOptions="Center"
                       TextColor="{StaticResource TextDark}" />
                <Label x:Name="TextLabel"
                       FontFamily="RobotoRegular"
                       FontSize="{StaticResource FontSizeBody}"
                       VerticalOptions="Center"
                       TextColor="{StaticResource TextDark}" />
            </HorizontalStackLayout>
        </Border>
    </Grid>

</ContentView>
