<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.PromptLabel">

    <Border BackgroundColor="{StaticResource LightBlue}"
            Stroke="Transparent"
            Padding="{StaticResource PromptPadding}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="{StaticResource CardCornerRadius}" />
        </Border.StrokeShape>

        <Border.Shadow>
            <Shadow Brush="{StaticResource CardShadowBrush}"
                    Offset="0,2"
                    Radius="{StaticResource PromptShadowRadius}"
                    Opacity="{StaticResource PromptShadowOpacity}" />
        </Border.Shadow>
        <Label x:Name="PromptText"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               TextColor="{StaticResource PrimaryDarkBlue}"
               FontFamily="RobotoRegular"
               FontSize="{StaticResource FontSizeTitleMedium}" />
    </Border>
</ContentView>
