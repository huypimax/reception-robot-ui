<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.NavRail">

    <Grid x:Name="RailContainer"
          BackgroundColor="{StaticResource PrimaryDarkBlue}"
          WidthRequest="{StaticResource NavRailCollapsedWidth}"
          VerticalOptions="Fill"
          IsClippedToBounds="True">

        <VerticalStackLayout Spacing="0" VerticalOptions="Start">

            <!-- ☰  Main — toggles the rail open/closed; label reads "Main" -->
            <Border HeightRequest="{StaticResource HeaderHeight}"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    Padding="{StaticResource NavRailItemPadding}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer x:Name="MenuTap" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="{StaticResource NavRailItemSpacing}"
                                       VerticalOptions="Center">
                    <Label Text="☰"
                           FontSize="{StaticResource FontSizeTitleLarge}"
                           TextColor="{StaticResource TextOnPrimary}"
                           WidthRequest="{StaticResource NavRailIconWidth}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center" />
                    <Label x:Name="MainText"
                           TextColor="{StaticResource TextOnPrimary}"
                           FontFamily="RobotoBold"
                           FontSize="{StaticResource FontSizeHeaderTitle}"
                           VerticalOptions="Center"
                           IsVisible="False" />
                </HorizontalStackLayout>
            </Border>

            <!-- Divider -->
            <BoxView HeightRequest="1"
                     Color="{StaticResource BorderLight}"
                     Margin="{StaticResource HeaderButtonPadding}" />

            <!-- QnA -->
            <Border HeightRequest="{StaticResource NavRailItemHeight}"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    Padding="{StaticResource NavRailItemPadding}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer x:Name="QnaTap" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="{StaticResource NavRailItemSpacing}"
                                       VerticalOptions="Center">
                    <Label Text="🎤"
                           FontSize="{StaticResource NavRailIconSize}"
                           WidthRequest="{StaticResource NavRailIconWidth}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center" />
                    <Label x:Name="QnaText"
                           TextColor="{StaticResource TextOnPrimary}"
                           FontFamily="RobotoRegular"
                           FontSize="{StaticResource FontSizeBody}"
                           VerticalOptions="Center"
                           IsVisible="False" />
                </HorizontalStackLayout>
            </Border>

            <!-- Navigation -->
            <Border HeightRequest="{StaticResource NavRailItemHeight}"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    Padding="{StaticResource NavRailItemPadding}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer x:Name="NaviTap" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="{StaticResource NavRailItemSpacing}"
                                       VerticalOptions="Center">
                    <Label Text="🗺️"
                           FontSize="{StaticResource NavRailIconSize}"
                           WidthRequest="{StaticResource NavRailIconWidth}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center" />
                    <Label x:Name="NaviText"
                           TextColor="{StaticResource TextOnPrimary}"
                           FontFamily="RobotoRegular"
                           FontSize="{StaticResource FontSizeBody}"
                           VerticalOptions="Center"
                           IsVisible="False" />
                </HorizontalStackLayout>
            </Border>

            <!-- Lab -->
            <Border HeightRequest="{StaticResource NavRailItemHeight}"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    Padding="{StaticResource NavRailItemPadding}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer x:Name="LabTap" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="{StaticResource NavRailItemSpacing}"
                                       VerticalOptions="Center">
                    <Label Text="🔬"
                           FontSize="{StaticResource NavRailIconSize}"
                           WidthRequest="{StaticResource NavRailIconWidth}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center" />
                    <Label x:Name="LabText"
                           TextColor="{StaticResource TextOnPrimary}"
                           FontFamily="RobotoRegular"
                           FontSize="{StaticResource FontSizeBody}"
                           VerticalOptions="Center"
                           IsVisible="False" />
                </HorizontalStackLayout>
            </Border>

            <!-- Delivery -->
            <Border HeightRequest="{StaticResource NavRailItemHeight}"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    Padding="{StaticResource NavRailItemPadding}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer x:Name="DeliTap" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="{StaticResource NavRailItemSpacing}"
                                       VerticalOptions="Center">
                    <Label Text="📦"
                           FontSize="{StaticResource NavRailIconSize}"
                           WidthRequest="{StaticResource NavRailIconWidth}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center" />
                    <Label x:Name="DeliText"
                           TextColor="{StaticResource TextOnPrimary}"
                           FontFamily="RobotoRegular"
                           FontSize="{StaticResource FontSizeBody}"
                           VerticalOptions="Center"
                           IsVisible="False" />
                </HorizontalStackLayout>
            </Border>

            <!-- Check-in -->
            <Border HeightRequest="{StaticResource NavRailItemHeight}"
                    BackgroundColor="Transparent"
                    Stroke="Transparent"
                    Padding="{StaticResource NavRailItemPadding}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer x:Name="CheckinTap" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="{StaticResource NavRailItemSpacing}"
                                       VerticalOptions="Center">
                    <Label Text="🏷️"
                           FontSize="{StaticResource NavRailIconSize}"
                           WidthRequest="{StaticResource NavRailIconWidth}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center" />
                    <Label x:Name="CheckinText"
                           TextColor="{StaticResource TextOnPrimary}"
                           FontFamily="RobotoRegular"
                           FontSize="{StaticResource FontSizeBody}"
                           VerticalOptions="Center"
                           IsVisible="False" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </Grid>

</ContentView>
