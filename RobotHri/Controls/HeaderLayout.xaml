<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.HeaderLayout">

    <Grid BackgroundColor="{StaticResource PrimaryDarkBlue}"
          HeightRequest="{StaticResource HeaderHeight}"
          Padding="{StaticResource HeaderPadding}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Back / Home button (left) -->
        <Border x:Name="BackButton"
                Grid.Column="0"
                BackgroundColor="Transparent"
                Stroke="Transparent"
                Padding="{StaticResource HeaderButtonPadding}"
                IsVisible="False"
                VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="{StaticResource HeaderButtonCornerRadius}" />
            </Border.StrokeShape>

            <Border.GestureRecognizers>
                <TapGestureRecognizer x:Name="BackTap" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout Spacing="{StaticResource SmallSpacing}">
                <Label Text="←"
                       TextColor="White"
                       FontSize="{StaticResource FontSizeTitleLarge}"
                       VerticalOptions="Center" />
                <Label x:Name="BackLabel"
                       TextColor="White"
                       FontFamily="RobotoRegular"
                       FontSize="{StaticResource FontSizeBody}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <!-- Title (center) -->
        <Label x:Name="TitleLabel"
               Grid.Column="1"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="White"
               FontFamily="RobotoBold"
               FontSize="{StaticResource FontSizeHeaderTitle}"
               HorizontalTextAlignment="Center" />

        <!-- Language button (right) -->
        <Border x:Name="LanguageButton"
                Grid.Column="2"
                BackgroundColor="{StaticResource OverlayLight}"
                Padding="12,6"
                VerticalOptions="Center">
            <Border.Stroke>
                <SolidColorBrush Color="{StaticResource BorderLight}" />
            </Border.Stroke>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <Border.GestureRecognizers>
                <TapGestureRecognizer x:Name="LanguageTap" />
            </Border.GestureRecognizers>
            <Label x:Name="LanguageLabel"
                   TextColor="White"
                   FontFamily="RobotoBold"
                   FontSize="{StaticResource FontSizeLanguage}" />
        </Border>
    </Grid>
</ContentView>
