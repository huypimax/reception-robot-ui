<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.HeaderLayout">

    <Grid BackgroundColor="{StaticResource PrimaryDarkBlue}"
          HeightRequest="72"
          Padding="16,0">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Back / Home button (left) -->
        <Border x:Name="BackButton"
                Grid.Column="0"
                BackgroundColor="Transparent"
                StrokeShape="RoundRectangle 8"
                Stroke="Transparent"
                Padding="8,6"
                IsVisible="False"
                VerticalOptions="Center">
            <Border.GestureRecognizers>
                <TapGestureRecognizer x:Name="BackTap" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout Spacing="4">
                <Label Text="←"
                       TextColor="White"
                       FontSize="20"
                       VerticalOptions="Center" />
                <Label x:Name="BackLabel"
                       TextColor="White"
                       FontFamily="RobotoRegular"
                       FontSize="14"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <!-- Title (center) -->
        <Label x:Name="TitleLabel"
               Grid.Column="1"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="White"
               FontFamily="RobotoBold"
               FontSize="22"
               HorizontalTextAlignment="Center" />

        <!-- Language button (right) -->
        <Border x:Name="LanguageButton"
                Grid.Column="2"
                BackgroundColor="#1AFFFFFF"
                StrokeShape="RoundRectangle 20"
                Stroke="#40FFFFFF"
                Padding="12,6"
                VerticalOptions="Center">
            <Border.GestureRecognizers>
                <TapGestureRecognizer x:Name="LanguageTap" />
            </Border.GestureRecognizers>
            <Label x:Name="LanguageLabel"
                   TextColor="White"
                   FontFamily="RobotoBold"
                   FontSize="13" />
        </Border>
    </Grid>
</ContentView>
