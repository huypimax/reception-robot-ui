<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RobotHri.Controls.SettingsToggleRow">

    <!--
        Settings row with a text label on the left and a state-pill + Switch on the right.
        Used for binary on/off settings (e.g. "Sound On/Off").
    -->
    <VerticalStackLayout Spacing="0">

        <Grid ColumnDefinitions="*,Auto"
              Padding="{StaticResource SettingsInfoRowPadding}">

            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                <Label x:Name="LabelView"
                       Style="{StaticResource BodyLabel}"
                       FontSize="{StaticResource FontSizeBody}" />
                <Label x:Name="DescView"
                       Style="{StaticResource SubtitleLabel}"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextColor="{StaticResource TextMuted}"
                       IsVisible="False" />
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="1"
                                   Spacing="10"
                                   VerticalOptions="Center">

                <!-- State pill: "Bật" / "Tắt" -->
                <Border x:Name="StatePill"
                        BackgroundColor="{StaticResource PrimaryDarkBlue}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="12,5">
                    <Label x:Name="StateLabel"
                           TextColor="{StaticResource TextOnPrimary}"
                           FontFamily="RobotoBold"
                           FontSize="{StaticResource FontSizeBody}" />
                </Border>

                <!-- Toggle switch -->
                <Switch x:Name="ToggleSwitch"
                        OnColor="{StaticResource PrimaryDarkBlue}"
                        VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Grid>

        <BoxView HeightRequest="1"
                 Color="{StaticResource LightBlue}"
                 HorizontalOptions="Fill" />

    </VerticalStackLayout>

</ContentView>
