<?xml version="1.0" encoding="utf-8" ?>
<controls:BaseContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:RobotHri.Controls.Base"
    xmlns:c="clr-namespace:RobotHri.Controls"
    xmlns:vm="clr-namespace:RobotHri.ViewModels"
    x:Class="RobotHri.Views.QnaPage"
    x:DataType="vm:QnaViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto"
          BackgroundColor="{StaticResource PageBackground}">

        <!-- Header -->
        <c:HeaderLayout Grid.Row="0"
                        x:Name="Header"
                        Title="{Binding TitleText}"
                        BackText="{Binding HomeText}"
                        ShowBackButton="True"
                        LanguageLabelText="{Binding LanguageLabel}" />

        <!-- Robot avatar + Response area -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20"
                                 Padding="24,24,24,12"
                                 HorizontalOptions="Center">

                <!-- Robot face placeholder -->
                <Border Style="{StaticResource CardBorder}"
                        HorizontalOptions="Center"
                        WidthRequest="180"
                        HeightRequest="180">
                    <VerticalStackLayout HorizontalOptions="Center"
                                        VerticalOptions="Center">
                        <Label Text="🤖"
                               FontSize="80"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <!-- Listening indicator -->
                        <ActivityIndicator IsRunning="{Binding IsListening}"
                                           IsVisible="{Binding IsListening}"
                                           Color="{StaticResource PrimaryDarkBlue}"
                                           WidthRequest="32"
                                           HeightRequest="32"
                                           HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Prompt / response text -->
                <c:PromptLabel Text="{Binding PromptText}"
                               HorizontalOptions="FillAndExpand" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Mic button -->
        <Border Grid.Row="2"
                HorizontalOptions="Center"
                Margin="0,0,0,16"
                WidthRequest="80"
                HeightRequest="80"
                StrokeShape="RoundRectangle 40"
                Stroke="Transparent">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleMicCommand}" />
            </Border.GestureRecognizers>
            <Border.Triggers>
                <DataTrigger TargetType="Border"
                             Binding="{Binding IsListening}"
                             Value="True">
                    <Setter Property="BackgroundColor" Value="{StaticResource DangerRed}" />
                </DataTrigger>
                <DataTrigger TargetType="Border"
                             Binding="{Binding IsListening}"
                             Value="False">
                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDarkBlue}" />
                </DataTrigger>
            </Border.Triggers>
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,4" Radius="10" Opacity="0.5" />
            </Border.Shadow>
            <Label FontFamily="RobotoBold"
                   FontSize="32"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <Label.Triggers>
                    <DataTrigger TargetType="Label"
                                 Binding="{Binding IsListening}"
                                 Value="True">
                        <Setter Property="Text" Value="⏹" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label"
                                 Binding="{Binding IsListening}"
                                 Value="False">
                        <Setter Property="Text" Value="🎤" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
        </Border>

        <!-- Speaker toggle row -->
        <HorizontalStackLayout Grid.Row="3"
                               HorizontalOptions="Center"
                               Spacing="16"
                               Margin="0,0,0,24">
            <Label Text="🔊"
                   FontSize="18"
                   VerticalOptions="Center" />
            <Label Text="AIko is ready"
                   Style="{StaticResource SubtitleLabel}"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Grid>
</controls:BaseContentPage>
