<?xml version="1.0" encoding="utf-8" ?>
<controls:BaseContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:RobotHri.Controls.Base"
    xmlns:c="clr-namespace:RobotHri.Controls"
    xmlns:vm="clr-namespace:RobotHri.ViewModels"
    x:Class="RobotHri.Views.MainPage"
    x:DataType="vm:MainViewModel"
    Shell.NavBarIsVisible="False">

    <!--
        Outer layout: [NavRail | Right side]
        The NavRail spans the full page height so its ☰ row aligns visually
        with the HeaderLayout, replacing the header's back-button slot.
    -->
    <Grid ColumnDefinitions="Auto,*">

        <!-- ── Navigation Rail (full-height left column) ── -->
        <c:NavRail Grid.Column="0"
                   VerticalOptions="Fill"
                   QnaCommand="{Binding NavigateQnaCommand}"
                   NaviCommand="{Binding NavigateNaviCommand}"
                   LabCommand="{Binding NavigateLabCommand}"
                   DeliCommand="{Binding NavigateDeliCommand}"
                   CheckinCommand="{Binding NavigateCheckinCommand}"
                   QnaLabel="{Binding BtnQna}"
                   NaviLabel="{Binding BtnNavigation}"
                   LabLabel="{Binding BtnLab}"
                   DeliLabel="{Binding BtnDelivery}"
                   CheckinLabel="{Binding BtnCheckin}" />

        <!-- ── Right side: Header  +  Content  +  Footer ── -->
        <Grid Grid.Column="1"
              RowDefinitions="Auto,Auto,*,Auto">

            <!-- Header (back button hidden — NavRail takes that role) -->
            <c:HeaderLayout Grid.Row="0"
                            x:Name="Header"
                            Title="{Binding TitleText}"
                            LanguageLabelText="{Binding LanguageLabel}"
                            ShowBackButton="False" />

            <!-- Welcome banner -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Margin="20,14,20,0">
                <Grid ColumnDefinitions="Auto,*"
                      Padding="{StaticResource SmallSpacing}">
                    <Label Grid.Column="0"
                           Text="🤖"
                           FontSize="{StaticResource FontSizeTitle}"
                           VerticalOptions="Center"
                           Margin="0,0,16,0" />
                    <Label Grid.Column="1"
                           Text="{Binding WelcomeText}"
                           Style="{StaticResource SubtitleLabel}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Start" />
                </Grid>
            </Border>

            <!-- Navigation cards (2 × 2) -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  RowDefinitions="*,*"
                  ColumnSpacing="14"
                  RowSpacing="14"
                  Padding="20,14,20,0">

                <!-- Q&A -->
                <Border Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource CardBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateQnaCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10"
                                         Padding="{StaticResource CardPadding}">
                        <Label Text="🎤"
                               FontSize="44"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding BtnQna}"
                               Style="{StaticResource TitleLabel}"
                               FontSize="{StaticResource FontSizeTitleMedium}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Navigation -->
                <Border Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource CardBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateNaviCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10"
                                         Padding="{StaticResource CardPadding}">
                        <Label Text="🗺️"
                               FontSize="44"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding BtnNavigation}"
                               Style="{StaticResource TitleLabel}"
                               FontSize="{StaticResource FontSizeTitleMedium}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Lab -->
                <Border Grid.Row="1" Grid.Column="0"
                        Style="{StaticResource CardBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateLabCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10"
                                         Padding="{StaticResource CardPadding}">
                        <Label Text="🔬"
                               FontSize="44"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding BtnLab}"
                               Style="{StaticResource TitleLabel}"
                               FontSize="{StaticResource FontSizeTitleMedium}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Delivery -->
                <Border Grid.Row="1" Grid.Column="1"
                        Style="{StaticResource CardBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateDeliCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10"
                                         Padding="{StaticResource CardPadding}">
                        <Label Text="📦"
                               FontSize="44"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding BtnDelivery}"
                               Style="{StaticResource TitleLabel}"
                               FontSize="{StaticResource FontSizeTitleMedium}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Check-in + footer -->
            <VerticalStackLayout Grid.Row="3"
                                 Padding="{StaticResource PagePadding}"
                                 Spacing="10">
                <c:RobotButton Text="{Binding BtnCheckin}"
                               ButtonStyle="Secondary"
                               Command="{Binding NavigateCheckinCommand}"
                               HeightRequest="{StaticResource ButtonHeight}"
                               HorizontalOptions="FillAndExpand" />
                <Label Text="Fablab @ HCMUT  •  AIko v2.0"
                       Style="{StaticResource SubtitleLabel}"
                       FontSize="{StaticResource FontSizeCaption}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

        </Grid>

    </Grid>
</controls:BaseContentPage>
