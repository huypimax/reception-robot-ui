<?xml version="1.0" encoding="utf-8" ?>
<controls:BaseContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:RobotHri.Controls.Base"
    xmlns:c="clr-namespace:RobotHri.Controls"
    xmlns:vm="clr-namespace:RobotHri.ViewModels"
    xmlns:models="clr-namespace:RobotHri.Models"
    x:Class="RobotHri.Views.NaviPage"
    x:DataType="vm:NaviViewModel"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <vm:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*"
          BackgroundColor="{StaticResource PageBackground}">

        <!-- Header -->
        <c:HeaderLayout Grid.Row="0"
                        x:Name="Header"
                        Title="{Binding TitleText}"
                        BackText="{Binding HomeText}"
                        ShowBackButton="True"
                        LanguageLabelText="{Binding LanguageLabel}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

        <!-- Prompt bar -->
        <c:PromptLabel Grid.Row="1"
                       Text="{Binding PromptText}"
                       Margin="24,16,24,0" />

        <!-- Room buttons grid -->
        <ScrollView Grid.Row="2">
            <FlexLayout BindableLayout.ItemsSource="{Binding AvailableRooms}"
                        Wrap="Wrap"
                        Direction="Row"
                        JustifyContent="SpaceBetween"
                        AlignItems="Start"
                        AlignContent="Start"
                        Padding="24,20">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:RoomButtonData">
                        <c:NavRoomButton RoomName="{Binding RoomName}"
                                         RoomKey="{Binding RoomKey}"
                                         IsActive="{Binding Source={RelativeSource AncestorType={x:Type vm:NaviViewModel}}, Path=ActiveRoomKey, Converter={x:Static vm:EqualityConverter.Instance}, ConverterParameter={Binding RoomKey}}"
                                         RoomSelected="OnRoomSelected"
                                         IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:NaviViewModel}}, Path=IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                         Margin="0,0,0,5"
                                         FlexLayout.Basis="32.5%" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </ScrollView>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsBusy}"
              BackgroundColor="#80000000"
              ZIndex="100">
            <c:LoadingPopupView BindingContext="{Binding .}" />
        </Grid>

        <!-- Notification Overlay -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsNotificationPopupVisible}"
              BackgroundColor="#80000000"
              ZIndex="101">
            <c:NotificationPopupView BindingContext="{Binding .}" />
        </Grid>

        <!-- Error Overlay -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsErrorPopupVisible}"
              BackgroundColor="#80000000"
              ZIndex="102">
            <c:ErrorPopupView BindingContext="{Binding .}" />
        </Grid>
    </Grid>
</controls:BaseContentPage>
