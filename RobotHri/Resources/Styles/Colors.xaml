<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ======== Brand Colors (from src/utilities/colors.py) ======== -->
    <Color x:Key="PrimaryDarkBlue">#00294D</Color>
    <Color x:Key="LightBlue">#D8E5FE</Color>
    <Color x:Key="HoverBg">#F0F6FF</Color>
    <Color x:Key="PageBackground">#EEF4FF</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="SuccessGreen">#2ECC71</Color>
    <Color x:Key="DangerRed">#AC0000</Color>
    <Color x:Key="AccentGreen">#69FF3D</Color>

    <!-- ======== Text Colors ======== -->
    <Color x:Key="TextDark">#00294D</Color>
    <Color x:Key="TextMuted">#6B7A8D</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- ======== Shadow / Overlay ======== -->
    <Color x:Key="ShadowColor">#40000000</Color>
    <Color x:Key="OverlayLight">#1AFFFFFF</Color>
    <Color x:Key="BorderLight">#40FFFFFF</Color>

    <!-- Brushes for shadows and borders -->
    <SolidColorBrush x:Key="CardShadowBrush" Color="#20000000" />
    <SolidColorBrush x:Key="ButtonShadowBrush" Color="#40000000" />
    <SolidColorBrush x:Key="OverlayLightBrush" Color="{StaticResource OverlayLight}" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLight}" />

    <!-- Semantic aliases -->
    <Color x:Key="Primary">#00294D</Color>
    <Color x:Key="Secondary">#D8E5FE</Color>
    <Color x:Key="Tertiary">#F0F6FF</Color>
</ResourceDictionary>
