<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Font sizes -->
    <x:Double x:Key="FontSizeTitle">24</x:Double>
    <x:Double x:Key="FontSizeTitleLarge">20</x:Double>
    <x:Double x:Key="FontSizeTitleMedium">18</x:Double>
    <x:Double x:Key="FontSizeHeaderTitle">22</x:Double>
    <x:Double x:Key="FontSizeSubtitle">16</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeLanguage">13</x:Double>
    <x:Double x:Key="FontSizeButton">16</x:Double>
    <x:Double x:Key="FontSizeRoomLabel">15</x:Double>

    <!-- Corner radii -->
    <CornerRadius x:Key="CardCornerRadius">20</CornerRadius>
    <CornerRadius x:Key="FieldCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="ButtonCornerRadius">30</CornerRadius>
    <CornerRadius x:Key="HeaderButtonCornerRadius">8</CornerRadius>

    <!-- Spacing / padding -->
    <Thickness x:Key="CardPadding">20</Thickness>
    <Thickness x:Key="FieldPadding">12,8</Thickness>
    <Thickness x:Key="PagePadding">20,16</Thickness>
    <Thickness x:Key="HeaderPadding">16,0</Thickness>
    <Thickness x:Key="HeaderButtonPadding">8,6</Thickness>
    <Thickness x:Key="PromptPadding">20,14</Thickness>
    <Thickness x:Key="NavRoomPadding">12,10</Thickness>

    <!-- Header -->
    <x:Double x:Key="HeaderHeight">72</x:Double>

    <!-- Button / control sizes -->
    <x:Double x:Key="ButtonMinWidth">120</x:Double>
    <x:Double x:Key="ButtonMinHeight">50</x:Double>
    <x:Double x:Key="ButtonHeight">52</x:Double>

    <!-- Nav room button -->
    <x:Double x:Key="NavRoomMinWidth">160</x:Double>
    <x:Double x:Key="NavRoomMinHeight">65</x:Double>
    <x:Double x:Key="NavRoomImageSize">26</x:Double>
    <x:Double x:Key="NavRoomStrokeThickness">2</x:Double>

    <!-- Shadow parameters (must be x:Single — Shadow.Radius and Shadow.Opacity are float) -->
    <x:Single x:Key="CardShadowRadius">10</x:Single>
    <x:Single x:Key="CardShadowOpacity">0.3</x:Single>
    <x:Single x:Key="PromptShadowRadius">6</x:Single>
    <x:Single x:Key="PromptShadowOpacity">0.3</x:Single>
    <x:Single x:Key="ButtonShadowRadius">8</x:Single>
    <x:Single x:Key="ButtonShadowOpacity">0.4</x:Single>
    <x:Single x:Key="NavRoomShadowRadius">6</x:Single>
    <x:Single x:Key="NavRoomShadowOpacity">0.3</x:Single>

    <!-- Small helper values -->
    <x:Double x:Key="SmallSpacing">4</x:Double>

    <!-- Settings / Setup page -->
    <x:Double x:Key="SettingsNavItemHeight">44</x:Double>
    <x:Double x:Key="SetupSidebarWidth">260</x:Double>
    <Thickness x:Key="SetupSidebarPadding">16,16</Thickness>
    <Thickness x:Key="SetupContentPadding">28,20</Thickness>
    <Thickness x:Key="SettingsNavItemInnerPadding">10,0</Thickness>
    <x:Double x:Key="SettingsNavIconWidth">22</x:Double>
    <x:Double x:Key="SettingsNavIconSize">16</x:Double>
    <x:Double x:Key="SettingsNavItemSpacing">10</x:Double>
    <Thickness x:Key="SettingsInfoRowPadding">0,12</Thickness>
    <x:Double x:Key="SettingsSliderValueBadgePadding">10</x:Double>

    <!-- NavRail -->
    <x:Double x:Key="NavRailCollapsedWidth">72</x:Double>
    <x:Double x:Key="NavRailExpandedWidth">200</x:Double>
    <x:Double x:Key="NavRailItemHeight">56</x:Double>
    <x:Double x:Key="NavRailIconSize">20</x:Double>
    <x:Double x:Key="NavRailIconWidth">28</x:Double>
    <x:Double x:Key="NavRailItemSpacing">14</x:Double>
    <Thickness x:Key="NavRailItemPadding">16,0,12,0</Thickness>

</ResourceDictionary>