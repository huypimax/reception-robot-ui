<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ======== Page Base ======== -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
    </Style>

    <!-- ======== Labels ======== -->
    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="RobotoBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
    </Style>

    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="RobotoRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSubtitle}" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="RobotoRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ======== Entry Fields ======== -->
    <Style x:Key="FormEntry" TargetType="Entry">
        <Setter Property="FontFamily" Value="RobotoRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
        <Setter Property="BackgroundColor" Value="{StaticResource White}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
    </Style>

    <!-- ======== Card Border ======== -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource White}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#20000000"
                        Offset="0,4"
                        Radius="10"
                        Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======== Form Field Container ======== -->
    <Style x:Key="FormFieldBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource White}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Stroke" Value="{StaticResource LightBlue}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Padding" Value="{StaticResource FieldPadding}" />
    </Style>

    <!-- ======== Picker ======== -->
    <Style x:Key="FormPicker" TargetType="Picker">
        <Setter Property="FontFamily" Value="RobotoRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
        <Setter Property="TitleColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>
</ResourceDictionary>
